# OpenAI (required for LLM and embeddings)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# NCBI / PubMed (optional but recommended to avoid rate limits)
# Register at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_ncbi_api_key
NCBI_EMAIL=your_email@example.com

# Qdrant (leave as-is for local in-memory mode, or point to a running instance)
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=your_qdrant_cloud_key  # only for Qdrant Cloud
QDRANT_COLLECTION=research_limitations
QDRANT_IN_MEMORY=true

# Chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval settings
RETRIEVAL_TOP_K=8

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Data paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
